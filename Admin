  { id: 84, name: "Çocuk Tişört",    price: 800,  image: `${CDN}/WhatsApp_Image_2026-05-16_at_14.23.45_2_rayugx.jpg`,          category: "cocuk", type: "tisort"   },
  { id: 85, name: "Çocuk Ceket",     price: 800,  image: `${CDN}/WhatsApp_Image_2026-05-16_at_14.23.44_1_lvqfgm.jpg`,          category: "cocuk", type: "ceket"    },
];

const DEFAULT_COUPONS = { "VELORA10": 10, "VELORA20": 20, "HOSGELDIN": 15 };
const DEFAULT_SETTINGS = {
  sitename: "VELORA",
  slogan: "Premium Giyim",
  whatsapp: "905550066123",
  banner: "",
  bannerActive: "0"
};
const ADMIN_USER = "admin";
const ADMIN_PASS_KEY = "velora_admin_pass";
const DEFAULT_PASS = "Velora2026!";

// ════════════════════════════════════════
// STATE
// ════════════════════════════════════════
let products = JSON.parse(localStorage.getItem("velora_admin_products")) || JSON.parse(JSON.stringify(DEFAULT_PRODUCTS));
let coupons  = JSON.parse(localStorage.getItem("velora_admin_coupons"))  || JSON.parse(JSON.stringify(DEFAULT_COUPONS));
let settings = JSON.parse(localStorage.getItem("velora_admin_settings")) || JSON.parse(JSON.stringify(DEFAULT_SETTINGS));

function saveProducts() { localStorage.setItem("velora_admin_products", JSON.stringify(products)); }
function saveCoupons()  { localStorage.setItem("velora_admin_coupons",  JSON.stringify(coupons)); }
function saveSettingsData() { localStorage.setItem("velora_admin_settings", JSON.stringify(settings)); }

// ════════════════════════════════════════
// GİRİŞ
// ════════════════════════════════════════
function doLogin() {
  const u = document.getElementById("login-user").value.trim();
  const p = document.getElementById("login-pass").value;
  const storedPass = localStorage.getItem(ADMIN_PASS_KEY) || DEFAULT_PASS;
  if (u === ADMIN_USER && p === storedPass) {
    document.getElementById("login-screen").style.display = "none";
    document.getElementById("admin-screen").style.display = "block";
    initAdmin();
  } else {
    document.getElementById("login-err").textContent = "Kullanıcı adı veya şifre hatalı.";
  }
}
document.getElementById("login-pass").addEventListener("keydown", e => { if (e.key === "Enter") doLogin(); });

function doLogout() {
  if (!confirm("Çıkış yapmak istediğinize emin misiniz?")) return;
  document.getElementById("admin-screen").style.display = "none";
  document.getElementById("login-screen").style.display = "flex";
  document.getElementById("login-pass").value = "";
  document.getElementById("login-err").textContent = "";
}

// ════════════════════════════════════════
// INIT
// ════════════════════════════════════════
function initAdmin() {
  updateDashboard();
  renderTable();
  renderCoupons();
  loadSettings();
}

// ════════════════════════════════════════
// TABS
// ════════════════════════════════════════
function switchTab(name, btn) {
  document.querySelectorAll(".tab-content").forEach(t => t.classList.remove("active"));
  document.querySelectorAll(".nav-btn").forEach(b => b.classList.remove("active"));
  document.getElementById("tab-" + name).classList.add("active");
  btn.classList.add("active");
  if (name === "urun-listesi") renderTable();
  if (name === "dashboard") updateDashboard();
}

// ════════════════════════════════════════
// DASHBOARD
// ════════════════════════════════════════
function updateDashboard() {
  document.getElementById("stat-total").textContent  = products.length;
  document.getElementById("stat-erkek").textContent  = products.filter(p => p.category === "erkek").length;
  document.getElementById("stat-kadin").textContent  = products.filter(p => p.category === "kadin").length;
  document.getElementById("stat-cocuk").textContent  = products.filter(p => p.category === "cocuk").length;
  document.getElementById("stat-kupon").textContent  = Object.keys(coupons).length;
  document.getElementById("stat-whatsapp").textContent = settings.whatsapp || "—";
  document.getElementById("stat-sitead").textContent   = settings.sitename || "—";
}

// ════════════════════════════════════════
// ÜRÜN EKLE
// ════════════════════════════════════════
document.getElementById("p-img").addEventListener("input", previewImage);

function previewImage() {
  const val = document.getElementById("p-img").value.trim();
  if (!val) { document.getElementById("preview-card").style.display = "none"; return; }
  const url = `${CDN}/${val}.jpg`;
  document.getElementById("preview-img").src = url;
  document.getElementById("preview-name").textContent = url;
  document.getElementById("preview-card").style.display = "block";
}

function addProduct() {
  const name  = document.getElementById("p-name").value.trim();
  const price = parseInt(document.getElementById("p-price").value);
  const cat   = document.getElementById("p-cat").value;
  const type  = document.getElementById("p-type").value;
  const img   = document.getElementById("p-img").value.trim();

  if (!name || !price || !img) { toast("Tüm alanları doldurun!", "err"); return; }

  const maxId = products.reduce((m, p) => Math.max(m, p.id), 0);
  products.push({
    id: maxId + 1,
    name,
    price,
    image: `${CDN}/${img}.jpg`,
    category: cat,
    type
  });
  saveProducts();
  toast(`"${name}" eklendi ✓`, "ok");
  clearForm();
  updateDashboard();
}

function clearForm() {
  ["p-name","p-price","p-img"].forEach(id => document.getElementById(id).value = "");
  document.getElementById("preview-card").style.display = "none";
}

// ════════════════════════════════════════
// ÜRÜN LİSTESİ
// ════════════════════════════════════════
function renderTable() {
  const cat    = document.getElementById("filter-cat").value;
  const type   = document.getElementById("filter-type").value;
  const search = document.getElementById("filter-search").value.toLowerCase();

  let list = products.filter(p => {
    if (cat    && p.category !== cat)  return false;
    if (type   && p.type     !== type) return false;
    if (search && !p.name.toLowerCase().includes(search)) return false;
    return true;
  });

  document.getElementById("table-count").textContent = list.length + " ürün";

  const tbody = document.getElementById("product-table");
  tbody.innerHTML = list.map(p => `
    <tr>
      <td style="color:var(--muted)">${p.id}</td>
      <td><img src="${p.image}" class="product-thumb" onerror="this.style.opacity=0.2"></td>
      <td>${p.name}</td>
      <td style="color:var(--gold)">${p.price.toLocaleString("tr-TR")} TL</td>
      <td><span class="badge badge-${p.category}">${p.category}</span></td>
      <td style="color:var(--muted)">${p.type}</td>
      <td>
        <div style="display:flex;gap:6px;">
          <button class="btn btn-blue btn-sm" onclick="openEdit(${p.id})">Düzenle</button>
          <button class="btn btn-red  btn-sm" onclick="deleteProduct(${p.id})">Sil</button>
        </div>
      </td>
    </tr>
  `).join("");
}

function deleteProduct(id) {
  const p = products.find(x => x.id === id);
  if (!confirm(`"${p?.name}" ürününü silmek istediğinize emin misiniz?`)) return;
  products = products.filter(x => x.id !== id);
  saveProducts();
  renderTable();
  updateDashboard();
  toast("Ürün silindi.", "ok");
}

// ════════════════════════════════════════
// DÜZENLE MODAL
// ════════════════════════════════════════
function openEdit(id) {
  const p = products.find(x => x.id === id);
  if (!p) return;
  document.getElementById("edit-id").value    = id;
  document.getElementById("edit-name").value  = p.name;
  document.getElementById("edit-price").value = p.price;
  document.getElementById("edit-cat").value   = p.category;
  document.getElementById("edit-type").value  = p.type;
  // dosya adını çıkar
  const imgKey = p.image.replace(CDN + "/", "").replace(".jpg", "");
  document.getElementById("edit-img").value   = imgKey;
  document.getElementById("edit-modal").classList.add("open");
}

function closeModal() {
  document.getElementById("edit-modal").classList.remove("open");
}

function saveEdit() {
  const id    = parseInt(document.getElementById("edit-id").value);
  const name  = document.getElementById("edit-name").value.trim();
  const price = parseInt(document.getElementById("edit-price").value);
  const cat   = document.getElementById("edit-cat").value;
  const type  = document.getElementById("edit-type").value;
  const img   = document.getElementById("edit-img").value.trim();

  if (!name || !price || !img) { toast("Tüm alanları doldurun!", "err"); return; }

  const idx = products.findIndex(x => x.id === id);
  if (idx === -1) return;
  products[idx] = { id, name, price, image: `${CDN}/${img}.jpg`, category: cat, type };
  saveProducts();
  closeModal();
  renderTable();
  updateDashboard();
  toast("Ürün güncellendi ✓", "ok");
}

document.getElementById("edit-modal").addEventListener("click", e => {
  if (e.target === document.getElementById("edit-modal")) closeModal();
});

// ════════════════════════════════════════
// KUPONLAR
// ════════════════════════════════════════
function addCoupon() {
  const code = document.getElementById("c-code").value.trim().toUpperCase();
  const pct  = parseInt(document.getElementById("c-pct").value);
  if (!code || !pct || pct < 1 || pct > 99) { toast("Geçerli kod ve oran girin!", "err"); return; }
  coupons[code] = pct;
  saveCoupons();
  renderCoupons();
  document.getElementById("c-code").value = "";
  document.getElementById("c-pct").value  = "";
  toast(`Kupon "${code}" eklendi ✓`, "ok");
}

function deleteCoupon(code) {
  if (!confirm(`"${code}" kuponunu silmek istiyor musunuz?`)) return;
  delete coupons[code];
  saveCoupons();
  renderCoupons();
  updateDashboard();
  toast("Kupon silindi.", "ok");
}

function renderCoupons() {
  const list = document.getElementById("coupon-list");
  const keys = Object.keys(coupons);
  if (keys.length === 0) {
    list.innerHTML = "<p style='color:var(--muted);font-size:12px;'>Henüz kupon yok.</p>";
    return;
  }
  list.innerHTML = keys.map(k => `
    <div class="coupon-item">
      <div>
        <span class="coupon-code">${k}</span>
        <span class="coupon-pct" style="margin-left:12px;">%${coupons[k]} indirim</span>
      </div>
      <button class="btn btn-red btn-sm" onclick="deleteCoupon('${k}')">Sil</button>
    </div>
  `).join("");
}

// ════════════════════════════════════════
// AYARLAR
// ════════════════════════════════════════
function loadSettings() {
  document.getElementById("s-sitename").value      = settings.sitename      || "";
  document.getElementById("s-slogan").value        = settings.slogan        || "";
  document.getElementById("s-whatsapp").value      = settings.whatsapp      || "";
  document.getElementById("s-banner").value        = settings.banner        || "";
  document.getElementById("s-banner-active").value = settings.bannerActive  || "0";
}

function saveSettings() {
  settings.sitename     = document.getElementById("s-sitename").value.trim();
  settings.slogan       = document.getElementById("s-slogan").value.trim();
  settings.whatsapp     = document.getElementById("s-whatsapp").value.trim();
  settings.banner       = document.getElementById("s-banner").value.trim();
  settings.bannerActive = document.getElementById("s-banner-active").value;
  saveSettingsData();
  updateDashboard();
  toast("Ayarlar kaydedildi ✓", "ok");
}

function changeAdminPw() {
  const oldPw  = document.getElementById("s-oldpw").value;
  const newPw  = document.getElementById("s-newpw").value;
  const newPw2 = document.getElementById("s-newpw2").value;
  const stored = localStorage.getItem(ADMIN_PASS_KEY) || DEFAULT_PASS;

  if (oldPw !== stored)    { toast("Mevcut şifre hatalı!", "err"); return; }
  if (newPw.length < 6)    { toast("Yeni şifre en az 6 karakter olmalı!", "err"); return; }
  if (newPw !== newPw2)    { toast("Şifreler eşleşmiyor!", "err"); return; }

  localStorage.setItem(ADMIN_PASS_KEY, newPw);
  document.getElementById("s-oldpw").value  = "";
  document.getElementById("s-newpw").value  = "";
  document.getElementById("s-newpw2").value = "";
  toast("Şifre güncellendi ✓", "ok");
}

// ════════════════════════════════════════
// KOD ÇIKTI
// ════════════════════════════════════════
function generateCode() {
  const lines = products.map(p => {
    const imgKey = p.image.replace(CDN + "/", "");
    return `  { id: ${p.id}, name: "${p.name}", price: ${p.price}, image: \`\${CDN}/${imgKey}\`, category: "${p.category}", type: "${p.type}" },`;
  });
  const code = `const CDN = "${CDN}";\n\nconst products = [\n${lines.join("\n")}\n];`;
  document.getElementById("code-output").value = code;
  toast("Kod oluşturuldu ✓", "ok");
}

function copyCode() {
  const el = document.getElementById("code-output");
  if (!el.value) { toast("Önce 'Kodu Oluştur'a bas!", "err"); return; }
  navigator.clipboard.writeText(el.value).then(() => toast("Kopyalandı ✓", "ok"));
}

// ════════════════════════════════════════
// TOAST
// ════════════════════════════════════════
function toast(msg, type = "") {
  const t = document.getElementById("toast");
  t.textContent = msg;
  t.className = "toast show " + type;
  clearTimeout(t._t);
  t._t = setTimeout(() => t.className = "toast", 3000);
}
</script>
</body>
</html>
