<!DOCTYPE html>
<html lang="tr">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>VELORA – Admin Paneli</title>
<link href="https://fonts.googleapis.com/css2?family=Montserrat:wght@300;400;500;600;700&family=Cormorant+Garamond:ital,wght@0,300;0,400;1,300;1,400&display=swap" rel="stylesheet">
<style>
:root {
  --bg: #0e0e0e;
  --surface: #1a1a1a;
  --surface2: #222222;
  --border: #2e2e2e;
  --gold: #C9A96E;
  --gold2: #a07840;
  --text: #f0ece4;
  --muted: #888;
  --red: #e05555;
  --green: #5ec47a;
  --blue: #5b8dee;
}

* { box-sizing: border-box; margin: 0; padding: 0; }

body {
  background: var(--bg);
  color: var(--text);
  font-family: 'Montserrat', sans-serif;
  font-size: 13px;
  min-height: 100vh;
}

/* ── LOGIN ── */
#login-screen {
  min-height: 100vh;
  display: flex;
  align-items: center;
  justify-content: center;
  background: radial-gradient(ellipse at 60% 40%, #1e1810 0%, #0e0e0e 70%);
}
.login-box {
  width: 380px;
  background: var(--surface);
  border: 1px solid var(--border);
  padding: 3rem 2.5rem;
  text-align: center;
}
.login-logo {
  font-family: 'Cormorant Garamond', serif;
  font-size: 2.2rem;
  font-weight: 300;
  letter-spacing: 0.3em;
  color: var(--gold);
  margin-bottom: 0.3rem;
}
.login-sub {
  font-size: 10px;
  letter-spacing: 0.25em;
  text-transform: uppercase;
  color: var(--muted);
  margin-bottom: 2.5rem;
}
.login-input {
  width: 100%;
  background: var(--surface2);
  border: 1px solid var(--border);
  color: var(--text);
  padding: 13px 16px;
  font-family: 'Montserrat', sans-serif;
  font-size: 13px;
  outline: none;
  margin-bottom: 12px;
  transition: border-color 0.2s;
}
.login-input:focus { border-color: var(--gold); }
.login-btn {
  width: 100%;
  background: var(--gold);
  color: #0e0e0e;
  border: none;
  padding: 14px;
  font-family: 'Montserrat', sans-serif;
  font-size: 11px;
  font-weight: 700;
  letter-spacing: 0.25em;
  text-transform: uppercase;
  cursor: pointer;
  transition: opacity 0.2s;
  margin-top: 4px;
}
.login-btn:hover { opacity: 0.85; }
.login-err {
  color: var(--red);
  font-size: 11px;
  margin-top: 10px;
  min-height: 16px;
}

/* ── LAYOUT ── */
#admin-screen { display: none; }
.admin-wrap {
  display: grid;
  grid-template-columns: 220px 1fr;
  min-height: 100vh;
}

/* ── SIDEBAR ── */
.sidebar {
  background: var(--surface);
  border-right: 1px solid var(--border);
  display: flex;
  flex-direction: column;
  position: sticky;
  top: 0;
  height: 100vh;
  overflow-y: auto;
}
.sidebar-logo {
  padding: 2rem 1.5rem 1.5rem;
  border-bottom: 1px solid var(--border);
}
.sidebar-logo-text {
  font-family: 'Cormorant Garamond', serif;
  font-size: 1.5rem;
  font-weight: 300;
  letter-spacing: 0.25em;
  color: var(--gold);
}
.sidebar-logo-sub {
  font-size: 9px;
  letter-spacing: 0.2em;
  text-transform: uppercase;
  color: var(--muted);
  margin-top: 2px;
}
.sidebar-nav { padding: 1rem 0; flex: 1; }
.nav-label {
  font-size: 9px;
  letter-spacing: 0.25em;
  text-transform: uppercase;
  color: var(--muted);
  padding: 0.8rem 1.5rem 0.4rem;
}
.nav-btn {
  display: flex;
  align-items: center;
  gap: 10px;
  width: 100%;
  padding: 11px 1.5rem;
  background: none;
  border: none;
  color: var(--muted);
  font-family: 'Montserrat', sans-serif;
  font-size: 12px;
  letter-spacing: 0.05em;
  cursor: pointer;
  text-align: left;
  transition: color 0.2s, background 0.2s;
  border-left: 2px solid transparent;
}
.nav-btn:hover { color: var(--text); background: var(--surface2); }
.nav-btn.active { color: var(--gold); border-left-color: var(--gold); background: rgba(201,169,110,0.07); }
.nav-icon { font-size: 15px; width: 18px; text-align: center; }
.sidebar-footer {
  padding: 1rem 1.5rem;
  border-top: 1px solid var(--border);
}
.logout-btn {
  width: 100%;
  background: none;
  border: 1px solid var(--border);
  color: var(--muted);
  padding: 9px;
  font-family: 'Montserrat', sans-serif;
  font-size: 10px;
  letter-spacing: 0.2em;
  text-transform: uppercase;
  cursor: pointer;
  transition: border-color 0.2s, color 0.2s;
}
.logout-btn:hover { border-color: var(--red); color: var(--red); }

/* ── MAIN ── */
.main { padding: 2.5rem; overflow-y: auto; }
.page-title {
  font-family: 'Cormorant Garamond', serif;
  font-size: 2rem;
  font-weight: 300;
  font-style: italic;
  color: var(--gold);
  margin-bottom: 0.3rem;
}
.page-sub {
  font-size: 10px;
  letter-spacing: 0.2em;
  text-transform: uppercase;
  color: var(--muted);
  margin-bottom: 2rem;
}

/* ── TABS ── */
.tab-content { display: none; }
.tab-content.active { display: block; }

/* ── CARDS ── */
.stats-grid {
  display: grid;
  grid-template-columns: repeat(4, 1fr);
  gap: 1rem;
  margin-bottom: 2rem;
}
.stat-card {
  background: var(--surface);
  border: 1px solid var(--border);
  padding: 1.5rem;
}
.stat-val {
  font-family: 'Cormorant Garamond', serif;
  font-size: 2.2rem;
  font-weight: 300;
  color: var(--gold);
}
.stat-lbl {
  font-size: 10px;
  letter-spacing: 0.15em;
  text-transform: uppercase;
  color: var(--muted);
  margin-top: 4px;
}

/* ── FORM ── */
.form-card {
  background: var(--surface);
  border: 1px solid var(--border);
  padding: 2rem;
  margin-bottom: 2rem;
}
.form-card-title {
  font-size: 11px;
  letter-spacing: 0.2em;
  text-transform: uppercase;
  color: var(--gold);
  margin-bottom: 1.5rem;
  padding-bottom: 0.75rem;
  border-bottom: 1px solid var(--border);
}
.form-grid {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 1rem;
}
.form-grid-3 {
  display: grid;
  grid-template-columns: 1fr 1fr 1fr;
  gap: 1rem;
}
.form-full { grid-column: 1 / -1; }
.form-group { display: flex; flex-direction: column; gap: 6px; }
.form-label {
  font-size: 10px;
  letter-spacing: 0.15em;
  text-transform: uppercase;
  color: var(--muted);
}
.form-input, .form-select {
  background: var(--surface2);
  border: 1px solid var(--border);
  color: var(--text);
  padding: 11px 14px;
  font-family: 'Montserrat', sans-serif;
  font-size: 12px;
  outline: none;
  transition: border-color 0.2s;
  width: 100%;
}
.form-input:focus, .form-select:focus { border-color: var(--gold); }
.form-select option { background: var(--surface2); }

.btn {
  padding: 11px 22px;
  border: none;
  font-family: 'Montserrat', sans-serif;
  font-size: 10px;
  font-weight: 600;
  letter-spacing: 0.2em;
  text-transform: uppercase;
  cursor: pointer;
  transition: opacity 0.2s, transform 0.15s;
}
.btn:hover { opacity: 0.85; transform: translateY(-1px); }
.btn-gold { background: var(--gold); color: #0e0e0e; }
.btn-red  { background: var(--red);  color: #fff; }
.btn-blue { background: var(--blue); color: #fff; }
.btn-outline {
  background: none;
  border: 1px solid var(--border);
  color: var(--muted);
}
.btn-outline:hover { border-color: var(--gold); color: var(--gold); }
.btn-sm { padding: 7px 14px; font-size: 9px; }

/* ── TABLE ── */
.table-wrap {
  background: var(--surface);
  border: 1px solid var(--border);
  overflow: hidden;
}
.table-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 1.25rem 1.5rem;
  border-bottom: 1px solid var(--border);
}
.table-title {
  font-size: 11px;
  letter-spacing: 0.2em;
  text-transform: uppercase;
  color: var(--gold);
}
.table-search {
  background: var(--surface2);
  border: 1px solid var(--border);
  color: var(--text);
  padding: 8px 12px;
  font-family: 'Montserrat', sans-serif;
  font-size: 12px;
  outline: none;
  width: 220px;
}
.table-search:focus { border-color: var(--gold); }
table {
  width: 100%;
  border-collapse: collapse;
}
th {
  text-align: left;
  padding: 10px 16px;
  font-size: 9px;
  letter-spacing: 0.2em;
  text-transform: uppercase;
  color: var(--muted);
  border-bottom: 1px solid var(--border);
  background: var(--surface2);
}
td {
  padding: 12px 16px;
  border-bottom: 1px solid var(--border);
  vertical-align: middle;
}
tr:last-child td { border-bottom: none; }
tr:hover td { background: rgba(255,255,255,0.02); }
.product-thumb {
  width: 44px;
  height: 56px;
  object-fit: cover;
  display: block;
}
.badge {
  display: inline-block;
  padding: 3px 9px;
  font-size: 9px;
  letter-spacing: 0.1em;
  text-transform: uppercase;
  border-radius: 2px;
}
.badge-erkek { background: rgba(91,141,238,0.15); color: var(--blue); }
.badge-kadin { background: rgba(201,169,110,0.15); color: var(--gold); }
.badge-cocuk { background: rgba(94,196,122,0.15); color: var(--green); }

/* ── KUPON ── */
.coupon-list { display: flex; flex-direction: column; gap: 10px; }
.coupon-item {
  display: flex;
  align-items: center;
  justify-content: space-between;
  background: var(--surface2);
  border: 1px solid var(--border);
  padding: 12px 16px;
}
.coupon-code {
  font-family: 'Montserrat', sans-serif;
  font-weight: 600;
  letter-spacing: 0.1em;
  color: var(--gold);
  font-size: 14px;
}
.coupon-pct { color: var(--muted); font-size: 12px; }

/* ── SETTINGS ── */
.settings-grid {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 1.5rem;
}

/* ── TOAST ── */
.toast {
  position: fixed;
  bottom: 2rem;
  right: 2rem;
  background: var(--surface);
  border: 1px solid var(--border);
  color: var(--text);
  padding: 14px 20px;
  font-size: 12px;
  letter-spacing: 0.05em;
  opacity: 0;
  transform: translateY(10px);
  transition: opacity 0.3s, transform 0.3s;
  pointer-events: none;
  z-index: 9999;
  max-width: 320px;
}
.toast.show { opacity: 1; transform: translateY(0); }
.toast.ok   { border-color: var(--green); color: var(--green); }
.toast.err  { border-color: var(--red);   color: var(--red); }

/* ── MODAL ── */
.modal-overlay {
  display: none;
  position: fixed; inset: 0;
  background: rgba(0,0,0,0.75);
  z-index: 1000;
  align-items: center;
  justify-content: center;
}
.modal-overlay.open { display: flex; }
.modal {
  background: var(--surface);
  border: 1px solid var(--border);
  padding: 2rem;
  width: 540px;
  max-width: 95vw;
  max-height: 90vh;
  overflow-y: auto;
}
.modal-title {
  font-size: 11px;
  letter-spacing: 0.2em;
  text-transform: uppercase;
  color: var(--gold);
  margin-bottom: 1.5rem;
  padding-bottom: 0.75rem;
  border-bottom: 1px solid var(--border);
}
.modal-actions { display: flex; gap: 10px; justify-content: flex-end; margin-top: 1.5rem; }

/* ── DIVIDER ── */
.section-gap { margin-bottom: 2rem; }

@media (max-width: 900px) {
  .admin-wrap { grid-template-columns: 1fr; }
  .sidebar { position: static; height: auto; }
  .stats-grid { grid-template-columns: 1fr 1fr; }
  .settings-grid { grid-template-columns: 1fr; }
}
</style>
</head>
<body>

<!-- ════════════ GİRİŞ ════════════ -->
<div id="login-screen">
  <div class="login-box">
    <div class="login-logo">VELORA</div>
    <div class="login-sub">Admin Paneli</div>
    <input type="text"     class="login-input" id="login-user" placeholder="Kullanıcı adı">
    <input type="password" class="login-input" id="login-pass" placeholder="Şifre">
    <button class="login-btn" onclick="doLogin()">Giriş Yap</button>
    <div class="login-err" id="login-err"></div>
  </div>
</div>

<!-- ════════════ ADMIN ════════════ -->
<div id="admin-screen">
  <div class="admin-wrap">

    <!-- SIDEBAR -->
    <aside class="sidebar">
      <div class="sidebar-logo">
        <div class="sidebar-logo-text">VELORA</div>
        <div class="sidebar-logo-sub">Admin Paneli</div>
      </div>
      <nav class="sidebar-nav">
        <div class="nav-label">Genel</div>
        <button class="nav-btn active" onclick="switchTab('dashboard', this)">
          <span class="nav-icon">📊</span> Dashboard
        </button>
        <div class="nav-label">Ürünler</div>
        <button class="nav-btn" onclick="switchTab('urun-ekle', this)">
          <span class="nav-icon">➕</span> Ürün Ekle
        </button>
        <button class="nav-btn" onclick="switchTab('urun-listesi', this)">
          <span class="nav-icon">📦</span> Ürün Listesi
        </button>
        <div class="nav-label">Pazarlama</div>
        <button class="nav-btn" onclick="switchTab('kuponlar', this)">
          <span class="nav-icon">🏷️</span> Kupon Kodları
        </button>
        <div class="nav-label">Site</div>
        <button class="nav-btn" onclick="switchTab('ayarlar', this)">
          <span class="nav-icon">⚙️</span> Site Ayarları
        </button>
        <button class="nav-btn" onclick="switchTab('kod-cikti', this)">
          <span class="nav-icon">💾</span> Kodu Dışa Aktar
        </button>
      </nav>
      <div class="sidebar-footer">
        <button class="logout-btn" onclick="doLogout()">Çıkış Yap</button>
      </div>
    </aside>

    <!-- MAIN -->
    <main class="main">

      <!-- DASHBOARD -->
      <div id="tab-dashboard" class="tab-content active">
        <div class="page-title">Dashboard</div>
        <div class="page-sub">Genel bakış</div>
        <div class="stats-grid">
          <div class="stat-card">
            <div class="stat-val" id="stat-total">0</div>
            <div class="stat-lbl">Toplam Ürün</div>
          </div>
          <div class="stat-card">
            <div class="stat-val" id="stat-erkek">0</div>
            <div class="stat-lbl">Erkek Ürünleri</div>
          </div>
          <div class="stat-card">
            <div class="stat-val" id="stat-kadin">0</div>
            <div class="stat-lbl">Kadın Ürünleri</div>
          </div>
          <div class="stat-card">
            <div class="stat-val" id="stat-cocuk">0</div>
            <div class="stat-lbl">Çocuk Ürünleri</div>
          </div>
        </div>
        <div class="stats-grid" style="grid-template-columns:1fr 1fr 1fr;">
          <div class="stat-card">
            <div class="stat-val" id="stat-kupon">0</div>
            <div class="stat-lbl">Aktif Kupon</div>
          </div>
          <div class="stat-card">
            <div class="stat-val" id="stat-whatsapp" style="font-size:1.1rem;padding-top:6px;"></div>
            <div class="stat-lbl">WhatsApp No</div>
          </div>
          <div class="stat-card">
            <div class="stat-val" id="stat-sitead" style="font-size:1.1rem;padding-top:6px;"></div>
            <div class="stat-lbl">Site Adı</div>
          </div>
        </div>
      </div>

      <!-- ÜRÜN EKLE -->
      <div id="tab-urun-ekle" class="tab-content">
        <div class="page-title">Ürün Ekle</div>
        <div class="page-sub">Yeni ürün bilgilerini girin</div>
        <div class="form-card">
          <div class="form-card-title">Ürün Bilgileri</div>
          <div class="form-grid">
            <div class="form-group">
              <label class="form-label">Ürün Adı</label>
              <input class="form-input" id="p-name" placeholder="Erkek Tişört">
            </div>
            <div class="form-group">
              <label class="form-label">Fiyat (TL)</label>
              <input class="form-input" id="p-price" type="number" placeholder="1200">
            </div>
            <div class="form-group">
              <label class="form-label">Kategori</label>
              <select class="form-select" id="p-cat">
                <option value="erkek">Erkek</option>
                <option value="kadin">Kadın</option>
                <option value="cocuk">Çocuk</option>
              </select>
            </div>
            <div class="form-group">
              <label class="form-label">Tür</label>
              <select class="form-select" id="p-type">
                <option value="tisort">Tişört</option>
                <option value="pantalon">Pantolon</option>
                <option value="sapka">Şapka</option>
                <option value="ceket">Ceket</option>
              </select>
            </div>
            <div class="form-group form-full">
              <label class="form-label">Cloudinary Fotoğraf Dosya Adı</label>
              <input class="form-input" id="p-img" placeholder="WhatsApp_Image_2026-05-16_at_12.49.26_9_mqf5za">
              <span style="font-size:10px;color:var(--muted);margin-top:4px;">.jpg uzantısını yazma, otomatik eklenir</span>
            </div>
          </div>
          <div style="margin-top:1.5rem; display:flex; gap:10px; align-items:center;">
            <button class="btn btn-gold" onclick="addProduct()">Ürünü Ekle</button>
            <button class="btn btn-outline" onclick="clearForm()">Temizle</button>
            <span id="add-preview-link" style="display:none;font-size:11px;color:var(--muted);"></span>
          </div>
        </div>

        <!-- Önizleme -->
        <div class="form-card" id="preview-card" style="display:none;">
          <div class="form-card-title">Fotoğraf Önizleme</div>
          <img id="preview-img" style="max-height:200px;object-fit:contain;background:var(--surface2);padding:8px;" alt="Önizleme">
          <div style="margin-top:10px;color:var(--muted);font-size:11px;" id="preview-name"></div>
        </div>
      </div>

      <!-- ÜRÜN LİSTESİ -->
      <div id="tab-urun-listesi" class="tab-content">
        <div class="page-title">Ürün Listesi</div>
        <div class="page-sub">Tüm ürünleri yönetin</div>

        <div style="display:flex;gap:10px;margin-bottom:1rem;flex-wrap:wrap;">
          <select class="form-select" id="filter-cat" style="width:160px;" onchange="renderTable()">
            <option value="">Tüm Kategoriler</option>
            <option value="erkek">Erkek</option>
            <option value="kadin">Kadın</option>
            <option value="cocuk">Çocuk</option>
          </select>
          <select class="form-select" id="filter-type" style="width:160px;" onchange="renderTable()">
            <option value="">Tüm Türler</option>
            <option value="tisort">Tişört</option>
            <option value="pantalon">Pantolon</option>
            <option value="sapka">Şapka</option>
            <option value="ceket">Ceket</option>
          </select>
          <input class="form-input" id="filter-search" style="width:200px;" placeholder="Ürün ara..." oninput="renderTable()">
        </div>

        <div class="table-wrap">
          <div class="table-header">
            <span class="table-title">Ürünler</span>
            <span id="table-count" style="font-size:11px;color:var(--muted);"></span>
          </div>
          <div style="overflow-x:auto;">
            <table>
              <thead>
                <tr>
                  <th>ID</th>
                  <th>Fotoğraf</th>
                  <th>Ad</th>
                  <th>Fiyat</th>
                  <th>Kategori</th>
                  <th>Tür</th>
                  <th>İşlem</th>
                </tr>
              </thead>
              <tbody id="product-table"></tbody>
            </table>
          </div>
        </div>
      </div>

      <!-- KUPONLAR -->
      <div id="tab-kuponlar" class="tab-content">
        <div class="page-title">Kupon Kodları</div>
        <div class="page-sub">İndirim kuponlarını yönetin</div>

        <div class="form-card">
          <div class="form-card-title">Yeni Kupon Ekle</div>
          <div class="form-grid-3">
            <div class="form-group">
              <label class="form-label">Kupon Kodu</label>
              <input class="form-input" id="c-code" placeholder="YENI25" style="text-transform:uppercase;">
            </div>
            <div class="form-group">
              <label class="form-label">İndirim Oranı (%)</label>
              <input class="form-input" id="c-pct" type="number" min="1" max="99" placeholder="25">
            </div>
            <div class="form-group" style="justify-content:flex-end;">
              <label class="form-label">&nbsp;</label>
              <button class="btn btn-gold" onclick="addCoupon()">Kupon Ekle</button>
            </div>
          </div>
        </div>

        <div class="form-card">
          <div class="form-card-title">Mevcut Kuponlar</div>
          <div class="coupon-list" id="coupon-list"></div>
        </div>
      </div>

      <!-- AYARLAR -->
      <div id="tab-ayarlar" class="tab-content">
        <div class="page-title">Site Ayarları</div>
        <div class="page-sub">Genel site konfigürasyonu</div>

        <div class="settings-grid">
          <div class="form-card">
            <div class="form-card-title">Genel Bilgiler</div>
            <div style="display:flex;flex-direction:column;gap:1rem;">
